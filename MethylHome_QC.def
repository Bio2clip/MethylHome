BootStrap: docker
From: ubuntu:24.04

%post

	# Versions
    version_R="4.4.3-1.2404.0"
    version_BiocManager="1.30.27"
    version_minfi="1.52.1"
    version_minfi_bioc="3.20"
    version_ewastools="1.8.0"
    version_dplyr="1.2.0"
    version_matrixStats="1.5.0"
    version_tidyr="1.3.2"
    version_readr="2.1.6"
    version_ggplot2="4.0.2"
    version_ggridges="0.5.7"
    version_patchwork="1.3.2"
    version_gridExtra="2.3"
    version_devtools="2.4.6"
    version_Matrix="1.7-4"
    version_survival="3.8-6"
    version_forcats="1.0.1"

    # Ubuntu packages
    apt-get -y update
	apt-get -y install build-essential wget unzip openjdk-17-jre
    apt-get -y update
    apt-get install -y \
        gfortran \
        libbz2-dev \
        zlib1g-dev \
        libbz2-dev \
        liblzma-dev \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libhdf5-dev \
        libpng-dev \
        libblas-dev \
        liblapack-dev \
        libfontconfig1-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        libfreetype6-dev \
        libtiff5-dev \
        libjpeg-dev \
        libwebp-dev 

    # Nextflow dependency
	apt-get -y install procps
    # R - add CRAN repository <https://cran.r-project.org/bin/linux/ubuntu/fullREADME.html>
    # Ubuntu
    # apt-get -y install wget gnupg
    echo "deb https://cloud.r-project.org/bin/linux/ubuntu noble-cran40/" >> /etc/apt/sources.list
    wget -qO- https://cloud.r-project.org/bin/linux/ubuntu/marutter_pubkey.asc | tee -a /etc/apt/trusted.gpg.d/cran_ubuntu_key.asc


    # R - install
	apt-get -y update
    apt-get install -y r-base=${version_R} r-base-core=${version_R} r-recommended=${version_R}

    # R - remotes package
    R -e "install.packages('remotes', repos='https://cloud.r-project.org')"  # To allow installing specific package verions

    # R - BiocManager package 
    R -e "remotes::install_version('BiocManager', version='${version_BiocManager}', repos='https://cloud.r-project.org')"
    
    # R - Matrix package
    R -e "remotes::install_version('Matrix', version='${version_Matrix}', repos='https://cloud.r-project.org')" # To have good version for minfi installation

    # R - survival package
    R -e "remotes::install_version('survival', version='${version_survival}', repos='https://cloud.r-project.org')" # To have good version for minfi installation

    # R - minfi package
    R -e "BiocManager::install('minfi', ask=FALSE, update=FALSE, version = '${version_minfi_bioc}')"

    # R - IlluminaHumanMethylationEPICv2manifest package
    R -e "BiocManager::install('IlluminaHumanMethylationEPICv2manifest', ask=FALSE, update=FALSE, version = '${version_minfi_bioc}')"

    # R - IlluminaHumanMethylationEPICv2anno.20a1.hg38 package
    R -e "BiocManager::install('IlluminaHumanMethylationEPICv2anno.20a1.hg38', ask=FALSE, update=FALSE, version = '${version_minfi_bioc}')"

    # R - ewastools package 
    R -e "remotes::install_github('hhhh5/ewastools', version='${version_ewastools}')"

    # R - dplyr package
    R -e "remotes::install_version('dplyr', version='${version_dplyr}', repos='https://cloud.r-project.org')"

    # R - matrixStats package
    R -e "remotes::install_version('matrixStats', version='${version_matrixStats}', repos='https://cloud.r-project.org')"

    # R - tidyr package
    R -e "remotes::install_version('tidyr', version='${version_tidyr}', repos='https://cloud.r-project.org')"

    # R readr package
    R -e "remotes::install_version('readr', version='${version_readr}', repos='https://cloud.r-project.org')"

    # R ggplot2 package  
    R -e "remotes::install_version('ggplot2', version='${version_ggplot2}', repos='https://cloud.r-project.org')"

    # R ggridges package 
    R -e "remotes::install_version('ggridges', version='${version_ggridges}', repos='https://cloud.r-project.org')"

    # R patchwork package 
    R -e "remotes::install_version('patchwork', version='${version_patchwork}', repos='https://cloud.r-project.org')"

    # R gridExtra package 
    R -e "remotes::install_version('gridExtra', version='${version_gridExtra}', repos='https://cloud.r-project.org')"

    # R forcats package 
    R -e "remotes::install_version('forcats', version='${version_forcats}', repos='https://cloud.r-project.org')"


    # Cleanup
    apt-get remove -y \
        gnupg \
        wget \
        build-essential \
        gfortran 

	apt-get -y auto-remove

%help
	This container is not meant to be used directly, but through Nextflow pipeline """ INSERER LE LIEN """

%labels
    Author Julie Durand
    Version 0.0.1